# ─────────────────────────────────────────────────────────────────────────────
# ICE Creates Clinical Decision Tracker — environment variables
# Copy this file to ".env.local" and fill in the real values.
# NEVER commit .env.local to git — it is git-ignored for a reason.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — get these from: Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only. Full database access — keep secret. Used by admin tasks
# (not required for normal user flows, which run under Row Level Security).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — transactional email (password reset). Optional until Phase 4.
# RESEND_API_KEY=re_your_key
# EMAIL_FROM=noreply@icecreates.com

# App URL — used for auth redirects (e.g. password recovery links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dev only: set to "true" to bypass auth and view the app with mock data,
# without needing a real Supabase session. Never active in production builds.
# DEV_BYPASS_AUTH=true
